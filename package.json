{
  "name": "dco",
  "private": true,
  "version": "1.0.0",
  "description": "a GitHub App that enforces the DCO on Pull Requests",
  "author": "Brandon Keepers",
  "license": "ISC",
  "repository": "github:dcoapp/app",
  "scripts": {
    "start": "probot run ./index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "posttest": "npm run lint",
    "lint": "prettier --check '{lib,test,docs}/**/*.{js,json,md}' index.js *.md package.json app.yml",
    "lint:fix": "prettier --write '{lib,test,docs}/**/*.{js,json,md}' index.js *.md package.json app.yml"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "email-validator": "^2.0.3",
    "prettier": "^2.5.1",
    "probot": "^14.3.2"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nock": "^14.0.0",
    "smee-client": "^1.0.1"
  },
  "standard": {
    "env": [
      "jest"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "statements": 100,
        "branches": 100,
        "functions": 100,
        "lines": 100
      }
    },
    "snapshotFormat": {
      "escapeString": true,
      "printBasicPrototype": true
    }
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
